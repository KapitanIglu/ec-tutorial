   {
     "name": "Creating Apps with GitHub",
     "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
     "features": {
       "ghcr.io/devcontainers/features/python:1": {}
     },
     "customizations": {
       "vscode": {
         "extensions": [
           "GitHub.copilot",
           "GitHub.copilot-chat",
           "ms-python.python"
         ],
         "settings": {
           "editor.formatOnSave": true
         }
       }
     },
     "forwardPorts": [5000],
    "postCreateCommand": "cd python && python3 -m venv .venv && . .venv/bin/activate && pip install -r requirements.txt"
    }